# MySQL (for docker-compose MySQL container — not used in production with external DB)
MYSQL_ROOT_PASSWORD=root123
MYSQL_PASSWORD=your_db_password

# Server
PORT=8080
DATABASE_DSN=pokeface:your_db_password@tcp(your_mysql_host:3306)/pokeface?parseTime=true

# JWT
JWT_SECRET=your-random-jwt-secret

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# LiveKit (production)
# LIVEKIT_HOST=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
